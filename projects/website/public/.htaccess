# =====================================================
# theinnovativenative.com - Apache Configuration
# =====================================================

# =====================================================
# SECURITY HEADERS
# =====================================================

# Prevent MIME type sniffing
Header set X-Content-Type-Options "nosniff"

# Clickjacking protection
Header set X-Frame-Options "SAMEORIGIN"

# XSS Protection (legacy browsers)
Header set X-XSS-Protection "1; mode=block"

# Referrer Policy
Header set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy (disable unused features)
Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

# Content Security Policy - Allow Stripe Buy Button iframe
Header set Content-Security-Policy "frame-src https://checkout.stripe.com https://js.stripe.com https://buy.stripe.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://calendly.com https://assets.calendly.com; frame-ancestors 'self';"

# Force HTTPS (uncomment when SSL is configured)
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# =====================================================
# DIRECTORY PROTECTION
# =====================================================

# Prevent directory listing
Options -Indexes

# Block access to hidden files (starting with .)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to sensitive files
<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
    Require all denied
</FilesMatch>


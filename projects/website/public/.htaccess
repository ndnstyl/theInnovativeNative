# =====================================================
# theinnovativenative.com - Apache Configuration
# =====================================================

# =====================================================
# REDIRECTS & URL NORMALIZATION
# =====================================================

RewriteEngine On

# HTTPS enforcement
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www to non-www redirect
RewriteCond %{HTTP_HOST} ^www\.theinnovativenative\.com [NC]
RewriteRule ^(.*)$ https://theinnovativenative.com/$1 [L,R=301]

# =====================================================
# SECURITY HEADERS
# =====================================================

# Prevent MIME type sniffing
Header set X-Content-Type-Options "nosniff"

# Clickjacking protection
Header set X-Frame-Options "SAMEORIGIN"

# XSS Protection (legacy browsers)
Header set X-XSS-Protection "1; mode=block"

# Referrer Policy
Header set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy (disable unused features)
Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

# Content Security Policy - Allow Stripe, Calendly, GTM, GA4, Meta Pixel
Header set Content-Security-Policy "frame-src https://checkout.stripe.com https://js.stripe.com https://buy.stripe.com https://www.googletagmanager.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://calendly.com https://assets.calendly.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net; frame-ancestors 'self'; img-src 'self' data: https: blob:;"

# HSTS - force HTTPS for all future visits
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# =====================================================
# DIRECTORY PROTECTION
# =====================================================

# Prevent directory listing
Options -Indexes

# Block access to hidden files (starting with .)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to sensitive files
<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
    Require all denied
</FilesMatch>

# =====================================================
# CACHING (Optional - uncomment to enable)
# =====================================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =====================================================
# COMPRESSION (Optional - uncomment to enable)
# =====================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

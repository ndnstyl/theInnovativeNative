{
  "mcpServers": {
    "archon": {
      "transport": "http",
      "url": "http://localhost:8051/mcp"
    },
    "n8n": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "N8N_API_URL": "https://n8n.srv948776.hstgr.cloud/",
        "N8N_API_KEY": "***REDACTED***"
      }
    },
    "playwright-mcp": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {
        "MCP_MODE": "stdio"
      }
    },
    "airtable-mcp": {
      "command": "npx",
      "args": ["-y", "airtable-mcp-server"],
      "env": {
        "AIRTABLE_API_KEY": "***REDACTED***"
      }
    },
    "notion-mcp": {
      "command": "npx",

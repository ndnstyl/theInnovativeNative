      "id": "wait-g4",
      "name": "Wait — G4 Approval Gate",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2640, 1200]
    },
    {
      "parameters": {
        "jsCode": "// Parse the script JSON to find shorts-worthy segments\n// Look for scenes that are good standalone clips: hooks, quote_cards, stat_callouts, topic_pivots\nconst episodeData = $('Airtable — Fetch Episode').first().json;\nconst episodeId = episodeData.fields['Episode ID'];\n\n// Re-fetch the script from the scenes to build timestamps\nconst scenes = $('Airtable — Fetch All Approved Scenes').all();\n\nlet currentTime = 3.5; // after intro\nconst shorts = [];\nlet shortSegmentStart = null;\nlet shortSegmentTitle = null;\nlet segmentScenes = [];\n\nfor (const scene of scenes) {\n  const s = scene.json.fields || scene.json;\n  const duration = s['Duration (seconds)'] || 10;\n  const pauseAfter = (s['Pause After (ms)'] || 0) / 1000;\n  const sceneType = s['Scene Type'];\n\n  // Start a new short segment on hook, topic_pivot, or quote_card\n  if (['hook', 'topic_pivot', 'quote_card'].includes(sceneType)) {\n    // If we have an accumulated segment that's long enough (30-90s), save it\n    if (shortSegmentStart !== null && segmentScenes.length >= 3) {\n      const segmentEnd = currentTime;\n      const segmentDuration = segmentEnd - shortSegmentStart;\n      if (segmentDuration >= 30 && segmentDuration <= 90) {\n        const startH = Math.floor(shortSegmentStart / 3600);\n        const startM = Math.floor((shortSegmentStart % 3600) / 60);\n        const startS = Math.floor(shortSegmentStart % 60);\n        const endH = Math.floor(segmentEnd / 3600);\n        const endM = Math.floor((segmentEnd % 3600) / 60);\n        const endS = Math.floor(segmentEnd % 60);\n        shorts.push({\n          start: `${String(startH).padStart(2,'0')}:${String(startM).padStart(2,'0')}:${String(startS).padStart(2,'0')}`,\n          end: `${String(endH).padStart(2,'0')}:${String(endM).padStart(2,'0')}:${String(endS).padStart(2,'0')}`,\n          title: `${episodeId}-short-${shorts.length + 1}-${shortSegmentTitle}`\n        });\n      }\n    }\n    shortSegmentStart = currentTime;\n    shortSegmentTitle = (s['Narration Text'] || sceneType).substring(0, 30).replace(/[^a-zA-Z0-9]/g, '-').toLowerCase();\n    segmentScenes = [];\n  }\n\n  segmentScenes.push(s);\n  currentTime += duration + pauseAfter;\n}\n\n// Capture last segment\nif (shortSegmentStart !== null && segmentScenes.length >= 3) {\n  const segmentEnd = currentTime;\n  const segmentDuration = segmentEnd - shortSegmentStart;\n  if (segmentDuration >= 30 && segmentDuration <= 90) {\n    const startH = Math.floor(shortSegmentStart / 3600);\n    const startM = Math.floor((shortSegmentStart % 3600) / 60);\n    const startS = Math.floor(shortSegmentStart % 60);\n    const endH = Math.floor(segmentEnd / 3600);\n    const endM = Math.floor((segmentEnd % 3600) / 60);\n    const endS = Math.floor(segmentEnd % 60);\n    shorts.push({\n      start: `${String(startH).padStart(2,'0')}:${String(startM).padStart(2,'0')}:${String(startS).padStart(2,'0')}`,\n      end: `${String(endH).padStart(2,'0')}:${String(endM).padStart(2,'0')}:${String(endS).padStart(2,'0')}`,\n      title: `${episodeId}-short-${shorts.length + 1}-${shortSegmentTitle}`\n    });\n  }\n}\n\n// Limit to top 5 shorts\nconst finalShorts = shorts.slice(0, 5);\n\nreturn [{ json: { shorts: finalShorts, episode_id: episodeId, shorts_count: finalShorts.length } }];"
      },
      "id": "extract-shorts-timestamps",
      "name": "Code — Extract Shorts Timestamps",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 1500]
    },
    {
      "parameters": {
        "jsCode": "const { shorts, episode_id } = $input.first().json;\nconst fs = require('fs');\nconst path = `/tmp/${episode_id}-shorts-timestamps.json`;\nfs.writeFileSync(path, JSON.stringify(shorts, null, 2), 'utf8');\nreturn [{ json: { timestamps_path: path, shorts, episode_id } }];"
      },

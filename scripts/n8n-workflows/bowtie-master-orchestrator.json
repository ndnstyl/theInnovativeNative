    {
      "parameters": {
        "jsCode": "// Build timeline EDL from approved scenes\nconst scenes = $input.all();\nconst episodeData = $('Airtable — Fetch Episode').first().json;\nconst episodeId = episodeData.fields['Episode ID'];\nconst episodeTitle = episodeData.fields['Title'];\n\nlet currentTime = 0;\nconst videoClips = [];\nconst voClips = [];\n\n// Add intro\nvideoClips.push({\n  id: 'V000', type: 'intro',\n  source: 'out/bowtie/intro.mp4',\n  in: 0, out: 3.5\n});\ncurrentTime = 3.5;\n\nfor (const scene of scenes) {\n  const s = scene.json.fields || scene.json;\n  const duration = s['Duration (seconds)'] || 10;\n  const pauseAfter = (s['Pause After (ms)'] || 0) / 1000;\n\n  const clipId = `V${String(videoClips.length).padStart(3, '0')}`;\n\n  if (s['Visual Backend'] === 'remotion') {\n    videoClips.push({\n      id: clipId, type: 'remotion_overlay',\n      source: `out/bowtie/remotion/${s['Scene Number']}.mov`,\n      in: currentTime, out: currentTime + duration\n    });\n  } else {\n    videoClips.push({\n      id: clipId, type: 'ken_burns',\n      source: s['Image File URL'] || 'MISSING',\n      in: currentTime, out: currentTime + duration,\n      ken_burns: { zoom_start: 1.0, zoom_end: 1.08, pan: 'slow_push' }\n    });\n  }\n\n  if (s['VO File URL']) {\n    voClips.push({\n      id: `VO${String(voClips.length).padStart(3, '0')}`,\n      source: s['VO File URL'],\n      in: currentTime,\n      out: currentTime + duration,\n      level_db: -13\n    });\n  }\n\n  currentTime += duration + pauseAfter;\n}\n\n// Add outro\nvideoClips.push({\n  id: `V${String(videoClips.length).padStart(3, '0')}`,\n  type: 'outro',\n  source: 'out/bowtie/outro.mp4',\n  in: currentTime, out: currentTime + 7\n});\n\nconst edl = {\n  episode_id: episodeId,\n  title: episodeTitle,\n  format: 'longform_16x9',\n  fps: 24,\n  target_duration_seconds: currentTime + 7,\n  tracks: { video: videoClips, voiceover: voClips, sfx: [], music: [], silence: [] },\n  master_output: {\n    normalization: '-14 LUFS',\n    true_peak: '-1 dBTP',\n    codec_video: 'libx264',\n    crf: 18,\n    codec_audio: 'aac',\n    bitrate_audio: '128k',\n    color_grade: 'eq=contrast=1.15:brightness=-0.03:saturation=0.75,unsharp=5:5:0.5'\n  }\n};\n\nreturn [{ json: { edl, edl_json: JSON.stringify(edl, null, 2) } }];"
      },

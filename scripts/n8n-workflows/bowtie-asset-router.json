    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.generation_status }}",
              "rightValue": "skipped",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            },
            {
              "leftValue": "={{ $json.airtable_record_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-should-update",
      "name": "IF — Should Update Airtable",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1620, 500]
    },
    {
      "parameters": {
        "jsCode": "// No Airtable update needed — pass data through to loop back\nconst item = $input.first().json;\nreturn [{ json: item }];"
      },

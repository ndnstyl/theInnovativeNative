      "position": [440, 300],
      "credentials": {
        "airtableTokenApi": {
          "id": "YCWFwTIXwnTpVy2y",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst episodeId = $('Webhook Trigger').first().json.body.episode_id;\n\n// Attach episode_id to each scene record for downstream use\nreturn items.map(item => {\n  return {\n    json: {\n      ...item.json,\n      episode_id: episodeId\n    }\n  };\n});"
      },
      "id": "enrich-scene-data",
      "name": "Enrich Scene Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "split-in-batches",
      "name": "SplitInBatches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "const scene = $input.first().json;\nconst narrationText = scene.narration_text || scene.fields?.narration_text || '';\n\n// Strip editorial pause markers — these are timeline cues, not spoken words.\n// Pauses are handled by pause_after field in timeline assembly, not TTS.\nlet voText = narrationText;\nvoText = voText.replace(/\\[2 second pause\\]/gi, '');\nvoText = voText.replace(/\\[1\\.5 second pause\\]/gi, '');\nvoText = voText.replace(/\\[1 second pause\\]/gi, '');\nvoText = voText.replace(/\\[beat\\]/gi, '');\nvoText = voText.replace(/\\[pause\\]/gi, '');\n\n// Clean up any double spaces or leading/trailing whitespace from stripped markers\nvoText = voText.replace(/  +/g, ' ').trim();\n\n// Send raw AAVE text to ElevenLabs — no SSML.\n// Scripts are already written in AAVE orthography per tyrone-voice-guide.md.\n// ElevenLabs voice settings (stability 0.50, style 0.36) handle natural cadence.\nreturn [{\n  json: {\n    ...scene,\n    vo_text: voText\n  }\n}];"
      },
      "id": "prepare-vo-text",
      "name": "Prepare VO Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 400]
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      },
      "id": "wait-rate-limit",
      "name": "Wait — Rate Limit",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [1320, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.elevenlabs.io/v1/text-to-speech/rWyjfFeMZ6PxkHqD3wGC",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: $json.vo_text, model_id: 'eleven_multilingual_v2', voice_settings: $json.voice_settings || { stability: 0.50, similarity_boost: 0.75, style: 0.36, speed: 0.92, use_speaker_boost: true } }) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "elevenlabs-tts",
      "name": "ElevenLabs — TTS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "",
          "name": "ElevenLabs API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const scene = $('Prepare VO Text').first().json;\nconst binaryData = $input.first().binary.data;\nconst sceneNumber = scene.scene_number || scene.fields?.scene_number || '000';\nconst filename = 'scene-' + sceneNumber + '-vo.mp3';\n\nreturn [{\n  json: {\n    ...scene,\n    vo_filename: filename\n  },\n  binary: {\n    data: {\n      ...binaryData,\n      fileName: filename,\n      mimeType: 'audio/mpeg',\n      fileExtension: 'mp3'\n    }\n  }\n}];"
      },
      "id": "prepare-upload",

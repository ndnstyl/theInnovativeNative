    {
      "parameters": {
        "jsCode": "const allItems = $('Airtable — Update Scene').all();\nconst episodeId = $('Webhook Trigger').first().json.body.episode_id;\n\nconst totalGenerated = allItems.length;\nconst sceneNumbers = allItems.map(i => i.json.scene_number || i.json.fields?.scene_number || 'unknown');\n\nconst summary = {\n  status: 'complete',\n  episode_id: episodeId,\n  total_vo_files: totalGenerated,\n  scenes_processed: sceneNumbers,\n  completed_at: new Date().toISOString()\n};\n\nreturn [{ json: summary }];"
      },

    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst attempts = (item.generation_attempts || 0) + 1;\nconst maxAttempts = 3;\n\nif (item.force_manual_review || attempts >= maxAttempts) {\n  // Max retries exhausted or parse failure → manual review\n  return [{\n    json: {\n      ...item,\n      update_status: 'manual_review',\n      generation_attempts: attempts\n    }\n  }];\n} else {\n  // Under max retries → send back for regeneration\n  return [{\n    json: {\n      ...item,\n      update_status: 'retry',\n      generation_attempts: attempts\n    }\n  }];\n}"
      },
      "id": "scene-qc-retry-logic",

      "id": "scene-qc-gdrive-download",
      "name": "Google Drive — Download",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1100, 500],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "53ssDoT9mG1Dtejj",
          "name": "Google Drive OAuth2"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{$credentials.googleGeminiApi.apiKey}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"inlineData\": {\n            \"mimeType\": \"{{ $binary.data.mimeType || 'image/png' }}\",\n            \"data\": \"{{ $binary.data.data }}\"\n          }\n        },\n        {\n          \"text\": \"Score this image 1-10 on the following criteria for the BowTie Bullies brand. Return JSON only, no markdown.\\n\\n1. Character consistency (coat color reddish-brown copper, red/liver nose, natural uncropped rose ears, scar left brow, black coveralls) — weight 3x\\n2. Mood match (dark, cinematic, not cheerful) — weight 2x\\n3. Art style (2D cel-shaded, not photorealistic, not 3D) — weight 2x\\n4. Composition quality (lighting, framing, vignette) — weight 1x\\n5. No banned elements (bowties, bright colors, multiple dogs, text, watermarks) — weight 3x\\n\\nFor environment/b-roll images (no character), score criterion 1 as 10 (n/a) and focus on criteria 2-5.\\n\\nReturn: {\\\"scores\\\": {\\\"consistency\\\": N, \\\"mood\\\": N, \\\"style\\\": N, \\\"composition\\\": N, \\\"banned_check\\\": N}, \\\"weighted_total\\\": N, \\\"pass\\\": true/false, \\\"notes\\\": \\\"...\\\"}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "scene-qc-gemini-score",
      "name": "Gemini — Score Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 500],
      "credentials": {
        "httpCustomAuth": {
          "id": "JbBNLCe83ER3tCwD",
          "name": "Google Gemini"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const geminiResponse = $input.first().json;\nconst sceneData = $('SplitInBatches').first().json;\n\nlet scoreData;\ntry {\n  // Gemini returns JSON in candidates[0].content.parts[0].text\n  const rawText = geminiResponse.candidates[0].content.parts[0].text;\n  scoreData = JSON.parse(rawText);\n} catch (e) {\n  // If scoring fails, default to manual review\n  return [{\n    json: {\n      ...sceneData,\n      qc_score: 0,\n      qc_pass: false,\n      qc_notes: `Score parsing failed: ${e.message}`,\n      force_manual_review: true\n    }\n  }];\n}\n\n// Calculate weighted total if Gemini didn't\nconst scores = scoreData.scores || {};\nconst weights = { consistency: 3, mood: 2, style: 2, composition: 1, banned_check: 3 };\nconst totalWeight = 3 + 2 + 2 + 1 + 3; // 11\nlet weightedTotal = scoreData.weighted_total;\n\nif (!weightedTotal && scores) {\n  weightedTotal = (\n    (scores.consistency || 0) * 3 +\n    (scores.mood || 0) * 2 +\n    (scores.style || 0) * 2 +\n    (scores.composition || 0) * 1 +\n    (scores.banned_check || 0) * 3\n  ) / totalWeight;\n  weightedTotal = Math.round(weightedTotal * 100) / 100;\n}\n\nconst pass = weightedTotal >= 7.0;\nconst attempts = (sceneData.generation_attempts || sceneData.fields?.generation_attempts || 0);\n\nreturn [{\n  json: {\n    ...sceneData,\n    qc_score: weightedTotal,\n    qc_pass: pass,\n    qc_notes: scoreData.notes || '',\n    qc_scores_detail: scores,\n    generation_attempts: attempts,\n    force_manual_review: false\n  }\n}];"
      },
      "id": "scene-qc-parse-score",

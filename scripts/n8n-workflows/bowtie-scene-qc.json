      "id": "scene-qc-loop-back",
      "name": "Loop Back",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [2640, 500]
    },
    {
      "parameters": {
        "jsCode": "const passed = $('Airtable — Mark Passed').all();\nconst failRetry = $('Airtable — Mark Fail/Retry').all();\nconst episodeId = $('Webhook Trigger').first().json.body?.episode_id || 'EP-001';\n\nconst retries = failRetry.filter(i => (i.json.update_status || i.json.fields?.update_status) === 'retry');\nconst manualReview = failRetry.filter(i => (i.json.update_status || i.json.fields?.update_status) === 'manual_review');\n\nconst summary = {\n  status: 'complete',\n  episode_id: episodeId,\n  total_scored: passed.length + failRetry.length,\n  passed: passed.length,\n  sent_for_retry: retries.length,\n  flagged_manual_review: manualReview.length,\n  completed_at: new Date().toISOString()\n};\n\nreturn [{ json: summary }];"
      },

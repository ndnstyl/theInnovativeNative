    {
      "parameters": {
        "jsCode": "// Validate output with ffprobe\nconst workDir = $('Code \u2014 Build Download Commands').first().json.workDir;\nconst validateCmd = `ffprobe -v quiet -print_format json -show_format -show_streams ${workDir}/reel_final.mp4`;\n\nreturn [{\n  json: {\n    validateCmd,\n    workDir\n  }\n}];"
      },
      "id": "tht-reel-build-validate",
      "name": "Code \u2014 Build Validate Command",

    {
      "parameters": {
        "command": "={{ $json.validateCmd }}",
        "timeout": 60
      },
      "id": "tht-reel-validate",
      "name": "Execute Command \u2014 Validate Output",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        3410,
        530
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse ffprobe output and validate specs\nconst output = $input.first().json.stdout;\nconst probe = JSON.parse(output);\nconst videoStream = probe.streams.find(s => s.codec_type === 'video');\nconst audioStream = probe.streams.find(s => s.codec_type === 'audio');\n\nconst errors = [];\n\nif (videoStream) {\n  if (videoStream.width !== 1080 || videoStream.height !== 1920) {\n    errors.push(`Resolution: ${videoStream.width}x${videoStream.height} (expected 1080x1920)`);\n  }\n  if (videoStream.codec_name !== 'h264') {\n    errors.push(`Video codec: ${videoStream.codec_name} (expected h264)`);\n  }\n} else {\n  errors.push('No video stream found');\n}\n\nif (!audioStream) {\n  errors.push('No audio stream found');\n}\n\n// Check file size\nconst fileSizeBytes = parseInt(probe.format.size || '0');\nconst fileSizeMB = fileSizeBytes / (1024 * 1024);\nif (fileSizeMB > 100) {\n  errors.push(`File size: ${fileSizeMB.toFixed(1)}MB (must be <100MB)`);\n}\n\nconst duration = parseFloat(probe.format.duration || '0');\n\nif (errors.length > 0) {\n  throw new Error(`Validation failed: ${errors.join('; ')}`);\n}\n\nconst workDir = $('Code \u2014 Build Download Commands').first().json.workDir;\n\nreturn [{\n  json: {\n    valid: true,\n    duration: Math.round(duration),\n    fileSizeMB: fileSizeMB.toFixed(1),\n    resolution: `${videoStream.width}x${videoStream.height}`,\n    codec: videoStream.codec_name,\n    reelPath: `${workDir}/reel_final.mp4`,\n    projectRecordId: $('Code \u2014 Build Download Commands').first().json.projectRecordId,\n    reelRecordId: $('Code \u2014 Build Download Commands').first().json.reelRecordId,\n    brandName: $('Code \u2014 Build Download Commands').first().json.brandName\n  }\n}];"
      },

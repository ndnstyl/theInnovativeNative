        "parameters": {
          "jsCode": "// Extract base64 image data from Gemini response and convert to binary\nconst geminiResponse = $input.first().json;\nconst sceneData = $('SplitInBatches').first().json;\n\n// Extract the base64 image from Gemini response\nlet base64Data;\nlet mimeType = 'image/png';\ntry {\n  const part = geminiResponse.candidates[0].content.parts[0];\n  base64Data = part.inlineData.data;\n  mimeType = part.inlineData.mimeType || 'image/png';\n} catch (e) {\n  // Generation failed \u2014 return error marker for downstream IF node\n  return [{\n    json: {\n      ...sceneData,\n      generation_failed: true,\n      error: `Failed to extract image: ${e.message}`,\n      raw_response: JSON.stringify(geminiResponse).substring(0, 500)\n    }\n  }];\n}\n\nconst filename = sceneData.target_filename || sceneData.fields?.target_filename || `scene-unknown-${Date.now()}.png`;\n\n// Convert base64 to binary\nconst binaryData = Buffer.from(base64Data, 'base64');\n\nreturn {\n  json: {\n    ...sceneData,\n    generation_failed: false,\n    filename: filename,\n    generated_at: new Date().toISOString(),\n    mime_type: mimeType\n  },\n  binary: {\n    data: await this.helpers.prepareBinaryData(\n      binaryData,\n      filename,\n      mimeType\n    )\n  }\n};"
        },

      },
      "id": "scene-gen-respond",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1320,
        140
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build Gemini payload \u2014 pass structured prompt directly (style slots already included)\nconst scene = $input.first().json;\nconst prompt = scene.visual_prompt_full || scene.fields?.visual_prompt_full || '';\n\nconst payload = {\n  contents: [\n    {\n      role: \"user\",\n      parts: [\n        {\n          text: prompt\n        }\n      ]\n    }\n  ],\n  generationConfig: {\n    responseModalities: [\"IMAGE\"],\n    imageConfig: {\n      aspectRatio: \"16:9\",\n      imageSize: \"2K\"\n    }\n  }\n};\n\nreturn [{ json: { ...scene, gemini_payload: payload } }];"
      },
      "id": "scene-gen-build-payload",
      "name": "Build Gemini Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        990,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://www.googleapis.com/drive/v3/files/{{ $json.id }}/permissions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"type\":\"anyone\",\"role\":\"reader\"}",
        "options": {}
      },
      "id": "scene-gen-share-file",
      "name": "Share File \u2014 Public",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1870,
        620
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "53ssDoT9mG1Dtejj",
          "name": "newGoogleDriveAPI"
        }

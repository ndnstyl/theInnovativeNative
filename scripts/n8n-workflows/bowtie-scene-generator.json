    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst episodeId = body.episode_id || 'EP-001';\nconst batchSize = body.batch_size || 10;\nconst sceneFrom = body.scene_from ? Number(body.scene_from) : null;\nconst sceneTo = body.scene_to ? Number(body.scene_to) : null;\nconst regenerate = body.regenerate === true || body.regenerate === 'true';\n\nconst clauses = [];\nclauses.push(`{episode_id}=\"${episodeId}\"`);\nif (!regenerate) clauses.push(`{generation_status}=\"ready_for_generation\"`);\nif (sceneFrom !== null) clauses.push(`{scene_number}>=${sceneFrom}`);\nif (sceneTo !== null) clauses.push(`{scene_number}<=${sceneTo}`);\n\nconst formula = clauses.length === 1 ? clauses[0] : `AND(${clauses.join(', ')})`;\n\nreturn [{ json: { formula, batch_size: batchSize, episode_id: episodeId,\n                   scene_from: sceneFrom, scene_to: sceneTo, regenerate } }];"
      },

          "jsCode": "const allUpdated = $('Airtable \u2014 Update Generated').all();\nconst allFailed = $('Airtable \u2014 Mark Failed').all();\nconst episodeId = $('Webhook Trigger').first().json.body?.episode_id || 'EP-001';\n\nconst summary = {\n  status: 'complete',\n  episode_id: episodeId,\n  total_generated: allUpdated.length,\n  total_failed: allFailed.length,\n  generated_files: allUpdated.map(i => i.json.target_filename || i.json.fields?.target_filename || 'unknown'),\n  completed_at: new Date().toISOString()\n};\n\nreturn [{ json: summary }];"

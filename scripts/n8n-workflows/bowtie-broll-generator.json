          "name": "Google Gemini"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key={{$credentials.googleGeminiApi.apiKey}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"text\": \"Generate a photorealistic image in 9:16 portrait format (1080x1920). {{ $json.body?.prompt_text ?? $json.prompt_text }}\\n\\nDo NOT include: {{ $json.body?.negative_prompt ?? $json.negative_prompt }}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseModalities\": [\"IMAGE\"],\n    \"imageConfig\": {\n      \"aspectRatio\": \"9:16\",\n      \"imageSize\": \"2K\"\n    }\n  }\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567804",
      "name": "Gemini Generate Portrait",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 580],
      "credentials": {
        "httpCustomAuth": {
          "id": "GEMINI_CREDENTIAL_ID",
          "name": "Google Gemini"
        }
      }
    },
    {
      "parameters": {
        "mode": "append",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567805",
      "name": "Merge Paths",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1000, 460]
    },
    {
      "parameters": {
        "jsCode": "// Extract base64 image data from Gemini response and convert to binary\nconst geminiResponse = $input.first().json;\nconst webhookData = $('Webhook Trigger').first().json.body;\n\n// Extract the base64 image from Gemini response\nlet base64Data;\ntry {\n  base64Data = geminiResponse.candidates[0].content.parts[0].inlineData.data;\n} catch (e) {\n  throw new Error(`Failed to extract image from Gemini response: ${e.message}. Response: ${JSON.stringify(geminiResponse).substring(0, 500)}`);\n}\n\nconst mimeType = geminiResponse.candidates[0].content.parts[0].inlineData.mimeType || 'image/png';\n\n// Build filename: bowtie-broll-{prompt_id}-{aspect_ratio}-{timestamp}.png\nconst aspectClean = webhookData.aspect_ratio.replace(':', 'x');\nconst timestamp = Date.now();\nconst filename = `bowtie-broll-${webhookData.prompt_id}-${aspectClean}-${timestamp}.png`;\n\n// Convert base64 to binary\nconst binaryData = Buffer.from(base64Data, 'base64');\n\nreturn {\n  json: {\n    prompt_id: webhookData.prompt_id,\n    prompt_text: webhookData.prompt_text,\n    negative_prompt: webhookData.negative_prompt,\n    aspect_ratio: webhookData.aspect_ratio,\n    category: webhookData.category,\n    episode_tags: webhookData.episode_tags,\n    mood: webhookData.mood,\n    filename: filename,\n    generated_date: new Date().toISOString(),\n    mime_type: mimeType\n  },\n  binary: {\n    data: await this.helpers.prepareBinaryData(\n      binaryData,\n      filename,\n      mimeType\n    )\n  }\n};"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567806",

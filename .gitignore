# ===========================================
# Second Brain Skills Template - .gitignore
# ===========================================

# ------------------------------------------
# PROPRIETARY/PERSONAL CONTENT (EXCLUDE)
# ------------------------------------------

# Your personal projects and business data
law_firm_RAG/
websiteStuff/
specs/
rizeToAirtable.md

# Personal/proprietary feature specs (ALL personal data)
# The folder structure is preserved via templates
.specify/features/

# Agent performance tracking (personal data)
.specify/memory/agents/performance.json

# Session logs and reports (contain personal data)
.specify/memory/reports/
.specify/memory/projects/time-log.json
.specify/features/**/session-log.md

# ------------------------------------------
# SECRETS & CREDENTIALS (NEVER COMMIT)
# ------------------------------------------

# Environment files
.env
.env.*
!.env.example

# API keys, tokens, credentials
*.pem
*.key
secrets/
credentials/

# ------------------------------------------
# DEPENDENCIES
# ------------------------------------------

# Node modules (reinstall via npm/yarn)
node_modules/
**/node_modules/

# Package lock files (optional - some prefer to include)
# package-lock.json
# yarn.lock

# ------------------------------------------
# BUILD OUTPUTS & CACHES
# ------------------------------------------

# Build directories
dist/
build/
.next/
out/
.output/

# Cache directories
.cache/
*.cache
.turbo/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# ------------------------------------------
# EDITOR & IDE
# ------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/

# Vim
*.swp
*.swo
*~

# ------------------------------------------
# OS GENERATED
# ------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ------------------------------------------
# LOGS & DEBUG
# ------------------------------------------

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Debug
.debug/

# ------------------------------------------
# REMOTION SPECIFIC
# ------------------------------------------

# Remotion video content
remotion-videos/
projects/006-ai-editing/remotion/

# ------------------------------------------
# LARGE BINARY / MEDIA DIRECTORIES
# ------------------------------------------

# ComfyUI models and outputs
comfyUI/
output/

# Python virtual environment
venv/

# Python cache
__pycache__/
**/__pycache__/
*.pyc

# Video editing project auto-saves and previews
projects/006-ai-editing/premiere/Adobe Premiere Pro Auto-Save/
projects/006-ai-editing/premiere/Adobe Premiere Pro Audio Previews/

# BowTie Bullies media assets (large binaries, stored on GDrive)
projects/004-bowtie-bullies/media/
projects/004-bowtie-bullies/assets/canonical-characters/
projects/004-bowtie-bullies/assets/EP-001/
projects/004-bowtie-bullies/assets/overlays/
projects/004-bowtie-bullies/assets/*.zip

# 006-ai-editing reference images (large, keep in GDrive)
projects/006-ai-editing/references/*.png
projects/006-ai-editing/references/*.jpg

# Legacy paths (kept until old dirs fully removed)
deliverables/004-faceless-ai-brand/broll/
deliverables/004-faceless-ai-brand/scenes/
deliverables/004-faceless-ai-brand/SFX/
deliverables/004-faceless-ai-brand/music/
deliverables/004-faceless-ai-brand/canonicalCharacter/
deliverables/004-faceless-ai-brand/assets/

# ------------------------------------------
# BACKUPS
# ------------------------------------------

# Backup files
*.bak
*.backup
backups/

# ------------------------------------------
# TEMPORARY FILES
# ------------------------------------------

# Temp directories
tmp/
temp/
.tmp/

# ------------------------------------------
# SENSITIVE AIRTABLE DATA
# ------------------------------------------

# Airtable exports (may contain sensitive data)
*.airtable.json

# ------------------------------------------
# WHAT TO INCLUDE (Override ignores)
# ------------------------------------------

# Keep template files even if parent is ignored
!.specify/templates/
!.specify/templates/**

# Keep a README in features to explain structure
!.specify/features/README.md

# Keep the skill structure
!.claude/skills/
!.claude/skills/**

# Keep constitution and shared learnings (they're the template)
!.specify/memory/constitution.md
!.specify/memory/learnings/shared-learnings.md

# Keep agent learnings structure (template value)
!.specify/memory/learnings/*-learnings.md

# Keep escalation matrix template
!.specify/memory/escalation-matrix.json

# Keep agent roster structure
!.specify/memory/agents/roster.json

# Project registry and logs contain personal data - exclude
.specify/memory/projects/
